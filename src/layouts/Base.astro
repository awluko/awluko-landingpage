---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Andrew Lukosevic - Cybersecurity Leader & Threat Hunter" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="flex flex-col min-h-screen bg-neutral-950 text-neutral-100">
    <header class="py-6 px-4">
      <nav class="max-w-2xl mx-auto flex justify-between items-center">
        <a href="/" class="text-xl font-bold text-neutral-100 hover:text-blue-400">Andrew Lukosevic</a>
        <div class="flex gap-6 text-sm text-neutral-400">
          <a href="/blog" class="hover:text-neutral-100">Posts</a>
          <a href="/about" class="hover:text-neutral-100">About</a>
        </div>
      </nav>
      <hr class="max-w-2xl mx-auto mt-6 border-neutral-800" />
    </header>

    <main class="flex-1 px-4 py-4">
      <div class="max-w-2xl mx-auto">
        <slot />
      </div>
    </main>

    <footer class="py-8 px-4 text-center text-sm text-neutral-500">
      <div class="max-w-2xl mx-auto">
        &copy; {new Date().getFullYear()} Andrew Lukosevic
      </div>
    </footer>
  </body>
</html>
